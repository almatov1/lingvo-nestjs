// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int         @id @default(autoincrement())
  telegramId    BigInt      @unique
  data          String?
  language      Language    @default(kk)
  level         Level?
  format        Format?

  currentStep   Step        @default(CHOOSE_LANGUAGE)
  testAnswers   Int[]

  currentTopic    Int?
  currentTask     TaskType?

  updatedAt   DateTime?   @updatedAt  @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)

  results   TopicResult[]
}

enum Language {
  kk
  ru
  en
}

enum Level {
  A1
  A2
  B1
  B2
  C1
}

enum Format {
  Online
  Offline
}

enum Step {
  CHOOSE_LANGUAGE
  REGISTRATION
  PLACEMENT_TEST
  LEARNING_FORMAT
  FORMAT_OFFLINE
  FORMAT_ONLINE
  COMPLETED
}

enum TaskType {
  READING
  WRITING
  LISTENING
  SPEAKING
}

model TopicResult {
  id    Int   @id @default(autoincrement())

  userId    Int
  level     Level
  topic     Int

  readingAnswers      Int[]
  writingAnswer       String?
  listeningAnswers    Int[]
  speakingFile        String?

  updatedAt   DateTime?   @updatedAt  @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id])

  @@unique([userId, level, topic])
}
